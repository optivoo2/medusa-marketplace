{
  "name": "medusa-marketplace",
  "version": "0.0.1",
  "description": "A starter for Medusa projects.",
  "author": "Medusa (https://medusajs.com)",
  "license": "MIT",
  "keywords": [
    "sqlite",
    "postgres",
    "typescript",
    "ecommerce",
    "headless",
    "medusa"
  ],
  "scripts": {
    "build": "medusa build",
    "seed": "medusa exec ./src/scripts/seed.ts",
    "seed:petrescue": "medusa exec ./src/scripts/seed-petrescue.ts",
    "prestart": "node scripts/pre-start.js",
    "start": "medusa start --host 0.0.0.0 --port $PORT",
    "dev": "medusa develop",
    "install:prod": "npm install --omit=dev --legacy-peer-deps",
    "migrate": "npx medusa db:migrate",
    "test:integration:http": "TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:integration:modules": "TEST_TYPE=integration:modules NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:unit": "TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit",
    "vercel:auth": "node scripts/auth-setup.js",
    "vercel:deploy": "node advanced-deploy.js deploy",
    "vercel:status": "node advanced-deploy.js status",
    "vercel:list": "node advanced-deploy.js list",
    "vercel:setup": "npm run vercel:auth",
    "railway:deploy": "node scripts/deploy-to-railway.js",
    "railway:setup-admin": "railway run node scripts/create-admin-and-api-key.js",
    "railway:get-key": "railway run node scripts/get-api-key.js"
  },
  "dependencies": {
    "@medusajs/admin-sdk": "2.10.2",
    "@medusajs/cache-redis": "^2.10.2",
    "@medusajs/cli": "2.10.2",
    "@medusajs/event-bus-redis": "^2.10.2",
    "@medusajs/framework": "2.10.2",
    "@medusajs/medusa": "2.10.2",
    "@mikro-orm/core": "6.4.3",
    "@mikro-orm/knex": "6.4.3",
    "@mikro-orm/migrations": "6.4.3",
    "@mikro-orm/postgresql": "6.4.3",
    "@modelcontextprotocol/sdk": "^1.25.2",
    "@opentelemetry/exporter-trace-otlp-http": "^0.52.1",
    "@vercel/sdk": "^1.18.6",
    "awilix": "^8.0.1",
    "date-fns": "^4.1.0",
    "mcp-handler": "^1.0.2",
    "pg": "^8.13.0",
    "redis": "^4.6.0",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@medusajs/test-utils": "2.10.2",
    "@mikro-orm/cli": "6.4.3",
    "@swc/core": "1.5.7",
    "@swc/jest": "^0.2.36",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "jest": "^29.7.0",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vite": "^5.2.11",
    "yalc": "^1.0.0-pre.53"
  },
  "engines": {
    "node": ">=20"
  }
}
