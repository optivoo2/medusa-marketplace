# URL do backend Medusa. Atualize com o domínio utilizado em produção (HTTPS recomendado)
MEDUSA_BACKEND_URL=http://localhost:9000

# Chave publicável associada ao sales channel utilizado pelo storefront
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=

# URL pública do storefront (utilizada para gerar links e metadados)
NEXT_PUBLIC_BASE_URL=http://localhost:8000

# Região padrão (ISO-2 minúsculo). Para Brasil utilize "br"
NEXT_PUBLIC_DEFAULT_REGION=br

# Chave pública do Stripe (opcional para doações futuras)
NEXT_PUBLIC_STRIPE_KEY=

# Segredo forte para revalidação on-demand (mínimo 32 caracteres aleatórios)
REVALIDATE_SECRET=
